{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "args": [],  // 确保为空
            "env": {},    // 确保为空
            "cwd": "${fileDirname}"  // 设置工作目录为文件所在目录
        }
    ]
}